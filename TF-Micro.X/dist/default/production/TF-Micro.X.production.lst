 33135   300000                     	org	3145728
 33136   300000  EC                 	db	236
 33137                           
 33138                           ;Config register CONFIG2 @ 0x300001
 33139                           ;	Clock out Enable bit
 33140                           ;	CLKOUTEN = OFF, CLKOUT function is disabled
 33141                           ;	PRLOCKED One-Way Set Enable bit
 33142                           ;	PR1WAY = ON, PRLOCKED bit can be cleared and set only once
 33143                           ;	Clock Switch Enable bit
 33144                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 33145                           ;	Fail-Safe Clock Monitor Enable bit
 33146                           ;	FCMEN = ON, Fail-Safe Clock Monitor enabled
 33147   300001                     	org	3145729
 33148   300001  FF                 	db	255
 33149                           
 33150                           ;Config register CONFIG3 @ 0x300002
 33151                           ;	MCLR Enable bit
 33152                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
 33153                           ;	Power-up timer selection bits
 33154                           ;	PWRTS = PWRT_64, PWRT set at 64ms
 33155                           ;	Multi-vector enable bit
 33156                           ;	MVECEN = ON, Multi-vector enabled, Vector table used for interrupts
 33157                           ;	IVTLOCK bit One-way set enable bit
 33158                           ;	IVT1WAY = ON, IVTLOCKED bit can be cleared and set only once
 33159                           ;	Low Power BOR Enable bit
