 32575   300000                     	org	3145728
 32576   300000  FC                 	db	252
 32577                           
 32578                           ;Config register CONFIG2 @ 0x300001
 32579                           ;	Clock out Enable bit
 32580                           ;	CLKOUTEN = OFF, CLKOUT function is disabled
