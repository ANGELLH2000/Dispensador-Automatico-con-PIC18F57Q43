 32582                           ;	PR1WAY = ON, PRLOCKED bit can be cleared and set only once
 32583                           ;	Clock Switch Enable bit
 32584                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 32585                           ;	Fail-Safe Clock Monitor Enable bit
 32586                           ;	FCMEN = ON, Fail-Safe Clock Monitor enabled
 32587   300001                     	org	3145729
 32588   300001  FF                 	db	255
 32589                           
 32590                           ;Config register CONFIG3 @ 0x300002
 32591                           ;	MCLR Enable bit
 32592                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
 32593                           ;	Power-up timer selection bits
 32594                           ;	PWRTS = PWRT_64, PWRT set at 64ms
 32595                           ;	Multi-vector enable bit
 32596                           ;	MVECEN = ON, Multi-vector enabled, Vector table used for interrupts
 32597                           ;	IVTLOCK bit One-way set enable bit
 32598                           ;	IVT1WAY = ON, IVTLOCKED bit can be cleared and set only once
 32599                           ;	Low Power BOR Enable bit
 32600                           ;	LPBOREN = OFF, Low-Power BOR disabled
 32601                           ;	Brown-out Reset Enable bits
 32602                           ;	BOREN = OFF, Brown-out Reset disabled
