 32028                           ;	RSTOSC = EXTOSC, EXTOSC operating per FEXTOSC bits (device manufacturing default)
 32029   300000                     	org	3145728
 32030   300000  FC                 	db	252
 32031                           
 32032                           ;Config register CONFIG2 @ 0x300001
 32033                           ;	Clock out Enable bit
 32034                           ;	CLKOUTEN = OFF, CLKOUT function is disabled
 32035                           ;	PRLOCKED One-Way Set Enable bit
 32036                           ;	PR1WAY = ON, PRLOCKED bit can be cleared and set only once
 32037                           ;	Clock Switch Enable bit
 32038                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 32039                           ;	Fail-Safe Clock Monitor Enable bit
 32040                           ;	FCMEN = ON, Fail-Safe Clock Monitor enabled
 32041   300001                     	org	3145729
 32042   300001  FF                 	db	255
 32043                           
 32044                           ;Config register CONFIG3 @ 0x300002
 32045                           ;	MCLR Enable bit
 32046                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
 32047                           ;	Power-up timer selection bits
 32048                           ;	PWRTS = PWRT_64, PWRT set at 64ms
 32049                           ;	Multi-vector enable bit
 32050                           ;	MVECEN = ON, Multi-vector enabled, Vector table used for interrupts
 32051                           ;	IVTLOCK bit One-way set enable bit
 32052                           ;	IVT1WAY = ON, IVTLOCKED bit can be cleared and set only once
 32053                           ;	Low Power BOR Enable bit
 32054                           ;	LPBOREN = OFF, Low-Power BOR disabled
 32055                           ;	Brown-out Reset Enable bits
 32056                           ;	BOREN = OFF, Brown-out Reset disabled
 32057   300002                     	org	3145730
 32058   300002  3D                 	db	61
 32059                           
 32060                           ;Config register CONFIG4 @ 0x300003
 32061                           ;	Brown-out Reset Voltage Selection bits
 32062                           ;	BORV = VBOR_1P9, Brown-out Reset Voltage (VBOR) set to 1.9V
 32063                           ;	ZCD Disable bit
 32064                           ;	ZCD = OFF, ZCD module is disabled. ZCD can be enabled by setting the ZCDSEN bit of ZCD
      +                          CON
 32065                           ;	PPSLOCK bit One-Way Set Enable bit
 32066                           ;	PPS1WAY = ON, PPSLOCKED bit can be cleared and set only once; PPS registers remain loc
      +                          ked after one clear/set cycle
 32067                           ;	Stack Full/Underflow Reset Enable bit
 32068                           ;	STVREN = ON, Stack full/underflow will cause Reset
 32069                           ;	Low Voltage Programming Enable bit
 32070                           ;	LVP = OFF, HV on MCLR/VPP must be used for programming
 32071                           ;	Extended Instruction Set Enable bit
 32072                           ;	XINST = OFF, Extended Instruction Set and Indexed Addressing Mode disabled
